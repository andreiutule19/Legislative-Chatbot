REDIS_URL=redis://localhost:6379/0

# Google Cloud / Vertex AI
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=europe-west3
RAG_CORPUS_NAME=projects/your-project/locations/your-location/ragCorpora/your-corpus-id
GEMINI_MODEL_NAME=gemini-2.5-flash
GOOGLE_API_KEY=your-api-key

# Service account key for RAG Engine (enables knowledge base retrieval)
# GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/sa-key.json

# CORS origins (comma-separated, "*" allows all)
CORS_ORIGINS=*

# Path to built React frontend (set by Dockerfile, leave empty for dev)
STATIC_DIR=
